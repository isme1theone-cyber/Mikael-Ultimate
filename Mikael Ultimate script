-- ===================== SIKTE FUNKSJONER =====================
local function getAimPart(char)
    if not char then return nil end
    local partName = targetParts[targetPartIndex]
    if partName == "Hodet" then
        return char:FindFirstChild("Head")
    elseif partName == "Kroppen" then
        return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    elseif partName == "Bena" then
        return char:FindFirstChild("LeftLowerLeg") or char:FindFirstChild("RightLowerLeg") or char:FindFirstChild("Left Leg") or char:FindFirstChild("Right Leg")
    end
    return char:FindFirstChild("Head")
end

local function isVisible(targetPart, character)
    if not wallCheckEnabled then return true end
    local castPoints = {camera.CFrame.Position, targetPart.Position}
    local ignoreList = {character}
    if player.Character then
        table.insert(ignoreList, player.Character)
    end
    local parts = camera:GetPartsObscuringTarget(castPoints, ignoreList)
    return #parts == 0
end

local cachedNPCs = {}
task.spawn(function()
    while task.wait(3) do
        if npcAimbotEnabled then
            local tempCache = {}
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") and obj ~= player.Character and not Players:GetPlayerFromCharacter(obj) then
                    if obj:FindFirstChildOfClass("Humanoid") then
                        table.insert(tempCache, obj)
                    end
                end
            end
            cachedNPCs = tempCache
        end
    end
end)

local function getClosestTargetToMouse()
    local targetObj = nil
    local targetPartRes = nil
    local shortestDistance = fovCircleEnabled and fovCircleRadius or math.huge

    local function sjekkKarakter(char)
        if not char then return end
        
        local p = Players:GetPlayerFromCharacter(char)
        if aimbotTeamCheckEnabled and p and p.Team == player.Team and player.Team ~= nil then
            return
        end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        
        local aimPart = getAimPart(char)
        if not aimPart then return end

        if not isVisible(aimPart, char) then return end

        local pos, onScreen = camera:WorldToViewportPoint(aimPart.Position)
        if onScreen then
            local mouseLocation = UserInputService:GetMouseLocation()
            local distance = (Vector2.new(pos.X, pos.Y) - mouseLocation).Magnitude
            if distance < shortestDistance then 
                shortestDistance = distance 
                targetObj = char
                targetPartRes = aimPart
            end
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then sjekkKarakter(p.Character) end
    end

    if npcAimbotEnabled then
        for _, obj in ipairs(cachedNPCs) do
            sjekkKarakter(obj)
        end
    end

    return targetObj, targetPartRes
end

