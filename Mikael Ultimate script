local function toggleFlyMode()
    flying = not flying
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local hum = getHumanoid()
    if flying then
        if hrp and hum then
            hum.PlatformStand = true
            bodyVelocity = Instance.new("BodyVelocity", hrp)
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro = Instance.new("BodyGyro", hrp)
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.P = 3000
            if flyBtn then
                flyBtn.Text = "Fly: PÅ"
                TweenService:Create(flyBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 60, 60)}):Play()
            end
        else
            flying = false 
        end
    else
        if hum then hum.PlatformStand = false end
        if bodyVelocity then bodyVelocity:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        if flyBtn then
            flyBtn.Text = "Fly: AV (F)"
            TweenService:Create(flyBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 55)}):Play()
        end
    end
end

