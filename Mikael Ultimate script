            local mouseLoc = UserInputService:GetMouseLocation()
            local screenRay = camera:ViewportPointToRay(mouseLoc.X, mouseLoc.Y)
            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            raycastParams.FilterDescendantsInstances = {player.Character}
            
            local rayResult = workspace:Raycast(screenRay.Origin, screenRay.Direction * 1000, raycastParams)
            if rayResult and rayResult.Instance then
                model = finnKarakterModell(rayResult.Instance)
            end
        end

        local validTargetChar = nil
        if model and model:FindFirstChildOfClass("Humanoid") and model:FindFirstChildOfClass("Humanoid").Health > 0 then
            if model ~= player.Character then
                local pTarget = Players:GetPlayerFromCharacter(model)
                local isNPC = (pTarget == nil)
                
                local canTrigger = false
                if pTarget then
                    if not (aimbotTeamCheckEnabled and pTarget.Team == player.Team and player.Team ~= nil) then
                        canTrigger = true
                    end
                elseif isNPC and npcAimbotEnabled then
                    canTrigger = true
                end
                
                if canTrigger then
                    validTargetChar = model
                end
            end
        end

        if validTargetChar then
            if currentTargetChar ~= validTargetChar then
                currentTargetChar = validTargetChar
                targetAcquiredTime = os.clock()
            end
            
            local timeHovered = os.clock() - targetAcquiredTime
            local delayInSeconds = triggerbotDelay / 1000
            local minInterval = 1 / triggerbotCPS
            
            if timeHovered >= delayInSeconds and (os.clock() - lastTrigger) >= minInterval then
                lastTrigger = os.clock()
                
                task.spawn(function()
                    if mouse1click then
                        mouse1click()
                    elseif mouse1press and mouse1release then
                        mouse1press()
                        task.wait(0.01)
                        mouse1release()
                    end
                    
                    pcall(function()
                        local vim = game:GetService("VirtualInputManager")
                        local mouseLoc = UserInputService:GetMouseLocation()
                        vim:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, true, game, 0)
                        task.wait(0.01)
                        vim:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, false, game, 0)
                    end)

                    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end)
            end
        else
            currentTargetChar = nil
            targetAcquiredTime = 0
        end
    else
        currentTargetChar = nil
        targetAcquiredTime = 0
    end

    if aimbotEnabled then
        local targetChar, targetPart = getClosestTargetToMouse()
        if targetPart then
            if aimbotInstaLock then 
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPart.Position)
            else 
                camera.CFrame = camera.CFrame:Lerp(CFrame.lookAt(camera.CFrame.Position, targetPart.Position), math.clamp(1 / aimbotSmoothness, 0, 1)) 
            end
        end
    end

    if hitboxEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart
                hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                hrp.Transparency = 0.6
                hrp.BrickColor = BrickColor.new("Bright red")
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = false 
            end
        end
    end

    if flying and bodyVelocity and bodyGyro then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local moveDir = Vector3.zero
            local cam = camera.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
            bodyVelocity.Velocity = moveDir * flySpeed
            bodyGyro.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + cam.LookVector)
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local char = p.Character
            
            if char then
                updateESP(char)
            end

            local isTeammate = (p.Team == player.Team and player.Team ~= nil)
            local showTracers = espLinesEnabled and not (espTeamCheckEnabled and isTeammate)

            if showTracers and char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                local tracer = tracerFrames[p.UserId]
                if not tracer then
                    tracer = Instance.new("Frame") 
                    tracer.AnchorPoint = Vector2.new(0.5, 0.5) 
                    tracer.BorderSizePixel = 0 
                    tracer.Parent = tracerFolder 
                    tracerFrames[p.UserId] = tracer
                end
                
                tracer.BackgroundColor3 = espColor
                
                local targetChest = char:FindFirstChild("HumanoidRootPart")
                if targetChest then
                    local vector, onScreen = camera:WorldToViewportPoint(targetChest.Position)
                    if onScreen then
                        tracer.Visible = true
                        local p1
                        if tracerOriginMode == 1 then
                            p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        elseif tracerOriginMode == 2 then
                            p1 = Vector2.new(camera.ViewportSize.X / 2, 0)
                        elseif tracerOriginMode == 3 then
                            local localHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                            if localHrp then
                                local lpVector, lpOnScreen = camera:WorldToViewportPoint(localHrp.Position)
                                p1 = Vector2.new(lpVector.X, lpVector.Y)
                                if not lpOnScreen then
                                    p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                                end
                            else
                                p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                            end
                        else
                            p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        end
                        
                        local p2 = Vector2.new(vector.X, vector.Y)
                        local distance = (p1 - p2).Magnitude
                        
                        tracer.Position = UDim2.new(0, (p1.X + p2.X) / 2, 0, (p1.Y + p2.Y) / 2)
                        tracer.Size = UDim2.new(0, distance, 0, 2) 
                        tracer.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
                    else 
                        tracer.Visible = false 
                    end
                end
            else 
                if tracerFrames[p.UserId] then tracerFrames[p.UserId].Visible = false end 
            end
            
            local showHighlight = espEnabled and not (espTeamCheckEnabled and isTeammate)
            if char and showHighlight then local h = char:FindFirstChild("MikaelESP") if h then h.FillColor = espColor end end
            
            local showNames = espNamesEnabled and not (espTeamCheckEnabled and isTeammate)
            if char and showNames then local nb = char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart:FindFirstChild("MikaelNameESP") if nb and nb:FindFirstChild("NameLabel") then nb.NameLabel.TextColor3 = espColor end end
        end
    end
end)

