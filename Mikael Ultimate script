local draggingMenu, resizingMenu = false, false
local dragStartPos, startFramePos, startScale

titleBar.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingMenu = true; dragStartPos = input.Position; startFramePos = mainFrame.Position end end)
resizeButton.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then resizingMenu = true; dragStartPos = input.Position; startScale = uiScale.Scale end end)

UserInputService.InputChanged:Connect(function(input)
    if draggingMenu and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        mainFrame.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + (input.Position.X - dragStartPos.X), startFramePos.Y.Scale, startFramePos.Y.Offset + (input.Position.Y - dragStartPos.Y))
    elseif resizingMenu and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        TweenService:Create(uiScale, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Scale = math.clamp(startScale + ((input.Position.Y - dragStartPos.Y) / 200), 0.5, 3)}):Play()
    end
end)

UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingMenu = false resizingMenu = false end end)

