-- ===================== HOVED LOOP (Fly, Tracers, Hitbox) =====================
RunService.RenderStepped:Connect(function()
    if hitboxEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart
                hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                hrp.Transparency = 0.6
                hrp.BrickColor = BrickColor.new("Bright red")
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = false 
            end
        end
    end

    if flying and bodyVelocity and bodyGyro then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local moveDir = Vector3.zero
            local cam = camera.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
            bodyVelocity.Velocity = moveDir * flySpeed
            bodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + cam.LookVector)
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local tracer = tracerFrames[p.UserId]
            local char = p.Character
            if espLinesEnabled and char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                if not tracer then
                    tracer = Instance.new("Frame")
                    tracer.AnchorPoint = Vector2.new(0.5, 0.5)
                    tracer.BackgroundColor3 = espColor
                    tracer.BorderSizePixel = 0
                    tracer.Parent = tracerFolder
                    tracerFrames[p.UserId] = tracer
                end

                local hrp = char.HumanoidRootPart
                local vector, onScreen = camera:WorldToViewportPoint(hrp.Position)

                if onScreen then
                    tracer.Visible = true
                    
                    local p1
                    if tracerOriginMode == 1 then
                        p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                    elseif tracerOriginMode == 2 then
                        p1 = Vector2.new(camera.ViewportSize.X / 2, 0)
                    else
                        local localHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if localHrp then
                            local hrpPos, _ = camera:WorldToViewportPoint(localHrp.Position)
                            p1 = Vector2.new(hrpPos.X, hrpPos.Y)
                        else
                            p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y) 
                        end
                    end
                    
                    local p2 = Vector2.new(vector.X, vector.Y)
                    local distance = (p1 - p2).Magnitude
                    local center = (p1 + p2) / 2

                    tracer.Position = UDim2.new(0, center.X, 0, center.Y)
                    tracer.Size = UDim2.new(0, distance, 0, 1.5) 
                    tracer.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
                else
                    tracer.Visible = false
                end
            else
                if tracer then tracer.Visible = false end
            end
        end
    end
end)

local function hookPlayer(p)
    if p == player then return end
    if p.Character then 
        task.spawn(function() updateESP(p.Character) end)
    end
    espConnections[p.UserId] = p.CharacterAdded:Connect(function(char)
        task.wait(0.5) updateESP(char)
    end)
end

for _, p in pairs(Players:GetPlayers()) do hookPlayer(p) end
Players.PlayerAdded:Connect(hookPlayer)
Players.PlayerRemoving:Connect(function(p)
    if espConnections[p.UserId] then espConnections[p.UserId]:Disconnect() espConnections[p.UserId] = nil end
    if tracerFrames[p.UserId] then tracerFrames[p.UserId]:Destroy() tracerFrames[p.UserId] = nil end
end)

