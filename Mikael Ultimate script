local function updateESP(char)
    if not char then return end
    local pChar = Players:GetPlayerFromCharacter(char)
    if pChar == player or not pChar then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")

    local highlight = char:FindFirstChild("MikaelESP")
    if espEnabled then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "MikaelESP"
            highlight.FillColor = espColor 
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = char
        end
    else
        if highlight then highlight:Destroy() end
    end

    if hrp and hum then
        local nameBbg = hrp:FindFirstChild("MikaelNameESP")
        if espNamesEnabled and hum.Health > 0 then
            if not nameBbg then
                nameBbg = Instance.new("BillboardGui")
                nameBbg.Name = "MikaelNameESP"
                nameBbg.Size = UDim2.new(0, 200, 0, 25)
                nameBbg.StudsOffset = Vector3.new(0, 3.5, 0) 
                nameBbg.AlwaysOnTop = true
                nameBbg.Parent = hrp

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Name = "NameLabel"
                nameLabel.Size = UDim2.new(1, 0, 1, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = pChar.Name
                nameLabel.TextColor3 = espColor
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextSize = 13
                nameLabel.TextXAlignment = Enum.TextXAlignment.Center
                nameLabel.TextStrokeTransparency = 0
                nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                nameLabel.Parent = nameBbg
            end
        else
            if nameBbg then nameBbg:Destroy() end
        end

        local healthBbg = hrp:FindFirstChild("MikaelHealthESP")
        if espHealthEnabled and hum.Health > 0 then
            if not healthBbg then
                healthBbg = Instance.new("BillboardGui")
                healthBbg.Name = "MikaelHealthESP"
                healthBbg.Size = UDim2.new(0, 5, 0, 45) 
                healthBbg.StudsOffset = Vector3.new(-1.2, 0, 0) 
                healthBbg.AlwaysOnTop = true
                healthBbg.Parent = hrp

                local healthBg = Instance.new("Frame")
                healthBg.Size = UDim2.new(1, 0, 1, 0)
                healthBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                healthBg.BorderSizePixel = 0
                Instance.new("UICorner", healthBg).CornerRadius = UDim.new(1, 0)
                healthBg.Parent = healthBbg

                local healthFill = Instance.new("Frame")
                healthFill.Name = "HealthFill"
                healthFill.Size = UDim2.new(1, 0, 1, 0)
                healthFill.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                healthFill.BorderSizePixel = 0
                Instance.new("UICorner", healthFill).CornerRadius = UDim.new(1, 0)
                healthFill.Parent = healthBg

                local function adjustBar()
                    if hum and healthFill then
                        local scale = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        healthFill.Size = UDim2.new(1, 0, scale, 0)
                        healthFill.Position = UDim2.new(0, 0, 1 - scale, 0)
                        healthFill.BackgroundColor3 = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 100), scale)
                    end
                end
                adjustBar()
          
                local conn = hum.HealthChanged:Connect(adjustBar)
                healthBbg.Destroying:Connect(function() conn:Disconnect() end)
            else
                local fill = healthBbg:FindFirstChild("HealthFill", true)
                if fill then
                    local scale = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    fill.Size = UDim2.new(1, 0, scale, 0)
                    fill.Position = UDim2.new(0, 0, 1 - scale, 0)
                end
            end
        else
