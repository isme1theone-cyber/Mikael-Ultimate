RunService.RenderStepped:Connect(function()
    local tid = os.clock()
    local rainbowColor = Color3.fromHSV((tid % 4) / 4, 0.8, 1)
    titleLabel.TextColor3 = rainbowColor
    mikaelLabel.TextColor3 = rainbowColor

    local greenHue = 0.33 + math.sin(tid * 2) * 0.08
    local sliderColor = Color3.fromHSV(greenHue, 0.85, 1)
    local textColor = Color3.fromHSV(greenHue, 0.4, 1) 
    for _, items in ipairs(animatedSliders) do
        items.fill.BackgroundColor3 = sliderColor
        items.label.TextColor3 = textColor
    end
    
    local redPulse = 0.5 + math.sin(tid * 4) * 0.5 
    local aggressiveRed = Color3.fromRGB(150 + (105 * redPulse), 20, 20)
    badgeStroke.Color = aggressiveRed
    versionText.TextColor3 = aggressiveRed

    if rainbowEspEnabled then espColor = Color3.fromHSV((tid % 3) / 3, 1, 1) end

    -- Trygg oppdatering av FOV sirkel (Hindrer krasj hvis executoren har ødelagt drawing API)
    if fovCircle then
        pcall(function()
            fovCircle.Visible = fovCircleEnabled
            if fovCircleEnabled then
                fovCircle.Position = UserInputService:GetMouseLocation()
                fovCircle.Radius = fovCircleRadius
                fovCircle.Color = espColor
            end
        end)
    end

    -- AIMBOT LOGIKK
    if aimbotEnabled then
        local target = getClosestPlayerToMouse()
        if target and target.Character then
            local aimPart = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
            if aimPart then
                if aimbotInstaLock then
                    camera.CFrame = CFrame.lookAt(camera.CFrame.Position, aimPart.Position)
                else
                    local targetCFrame = CFrame.lookAt(camera.CFrame.Position, aimPart.Position)
                    local smoothSpeed = math.clamp(1 / aimbotSmoothness, 0, 1)
                    camera.CFrame = camera.CFrame:Lerp(targetCFrame, smoothSpeed)
                end
            end
        end
    end

    -- HITBOX EXPANDER LOGIKK
    if hitboxEnabled then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = p.Character.HumanoidRootPart
                hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                hrp.Transparency = 0.6
                hrp.BrickColor = BrickColor.new("Bright red")
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = false 
            end
        end
    end

    -- FLY LOGIKK
    if flying and bodyVelocity and bodyGyro then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local moveDir = Vector3.zero
            local cam = camera.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
            if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
            bodyVelocity.Velocity = moveDir * flySpeed
            bodyGyro.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + cam.LookVector)
        end
    end

    -- TRACERS (LINJER) LIVE OPPDATERING (Ren og trygg Luau-struktur)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local tracer = tracerFrames[p.UserId]
            local char = p.Character
            
            if espLinesEnabled and char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                if not tracer then
                    tracer = Instance.new("Frame")
                    tracer.AnchorPoint = Vector2.new(0.5, 0.5)
                    tracer.BorderSizePixel = 0
                    tracer.Parent = tracerFolder
                    tracerFrames[p.UserId] = tracer
                end
                tracer.BackgroundColor3 = espColor

                local targetChest = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
                if targetChest then
                    local vector, onScreen = camera:WorldToViewportPoint(targetChest.Position)

                    if onScreen then
                        tracer.Visible = true
                        local p1
                        if tracerOriginMode == 1 then 
                            p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        elseif tracerOriginMode == 2 then 
                            p1 = Vector2.new(camera.ViewportSize.X / 2, 0)
                        else
                            local localChest = player.Character and (player.Character:FindFirstChild("UpperTorso") or player.Character:FindFirstChild("Torso") or player.Character:FindFirstChild("HumanoidRootPart"))
                            if localChest then 
                                local chestPos = camera:WorldToViewportPoint(localChest.Position) 
                                p1 = Vector2.new(chestPos.X, chestPos.Y)
                            else 
                                p1 = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y) 
                            end
                        end
                        local p2 = Vector2.new(vector.X, vector.Y)
                        local distance = (p1 - p2).Magnitude
                        local center = (p1 + p2) / 2
                        tracer.Position = UDim2.new(0, center.X, 0, center.Y)
                        tracer.Size = UDim2.new(0, distance, 0, 1.5) 
                        tracer.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
                    else 
                        tracer.Visible = false 
                    end
                end
            else 
                if tracer then 
                    tracer.Visible = false 
                end 
            end
            
            -- Fargeoppdatering på ESP bokser/navn
            if char and espEnabled then 
                local h = char:FindFirstChild("MikaelESP") 
                if h then h.FillColor = espColor end 
            end
            if char and espNamesEnabled then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local nb = hrp and hrp:FindFirstChild("MikaelNameESP")
                local lbl = nb and nb:FindFirstChild("NameLabel")
                if lbl then lbl.TextColor3 = espColor end
            end
        end
    end
end)

