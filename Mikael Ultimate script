UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if isChangingKey then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            menuKeybind = input.KeyCode
            keybindBtn.Text = "Åpne/Lukk Meny: " .. menuKeybind.Name
            TweenService:Create(keybindBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 55)}):Play()
            isChangingKey = false
        end
        return 
    end

    if not gameProcessed and input.KeyCode == menuKeybind then
        menuOpen = not menuOpen
        if menuOpen then
            mainFrame.Visible = true
            TweenService:Create(uiScale, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
        else
            local closeTween = TweenService:Create(uiScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0})
            closeTween:Play()
            task.spawn(function()
                closeTween.Completed:Wait()
                if not menuOpen then
                    mainFrame.Visible = false
                end
            end)
        end
    end

    if not gameProcessed and input.KeyCode == Enum.KeyCode.F then toggleFlyMode() end
    if not gameProcessed and clickTpEnabled and input.UserInputType == Enum.UserInputType.MouseButton1 then
        if mouse.Hit and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then player.Character.HumanoidRootPart.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3.5, 0)) end
    end
end)

