    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        onClick(btn)
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, width - 4, 0, 31), Position = UDim2.new(0, xPos + 2, 0, yPos + 2)}):Play()
        task.wait(0.1)
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, width, 0, 35), Position = UDim2.new(0, xPos, 0, yPos)}):Play()
    end)
